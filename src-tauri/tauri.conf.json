{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "InterviewPilot",
  "version": "0.1.0",
  "identifier": "com.interviewpilot.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "InterviewPilot",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "overlay",
        "title": "",
        "url": "/overlay.html",
        "width": 400,
        "height": 600,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "contentProtected": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false,
        "hiddenTitle": true,
        "x": 50,
        "y": 100
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "global-shortcut": {},
    "shell": {}
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.3",
      "signingIdentity": null,
      "frameworks": []
    }
  }
}
